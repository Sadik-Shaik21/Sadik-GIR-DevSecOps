pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "sadikshaik21/task30-app:latest"
    }

    stages {
        stage('Clone Repository') {
            steps {
                echo 'Pulling the latest source files...'
            }
        }

        stage('Gitleaks Secret Scan') {
            steps {
                echo 'Running Gitleaks to sweep for exposed credentials or API keys...'
                bat 'gitleaks detect --verbose'
            }
        }

        stage('OWASP Dependency Scan') {
            steps {
                echo 'Invoking OWASP Dependency-Check via Maven...'
                // Navigates into the task 30 folder to find the pom.xml
                dir('task 30') {
                    bat 'mvn org.owasp:dependency-check-maven:check -DautoUpdate=false'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Compiling resources and building the Docker container layout...'
                // Navigates into the task 30 folder to find the Dockerfile
                dir('task 30') {
                    bat "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                echo 'Invoking Trivy scanner to scan the built container layer vulnerabilities...'
                bat "trivy image ${DOCKER_IMAGE}"
            }
        }

        stage('Publish to Docker Hub') {
            steps {
                echo 'Authenticating and pushing the image to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', 
                                                 usernameVariable: 'DOCKER_USER', 
                                                 passwordVariable: 'DOCKER_PASS')]) {
                    bat "docker login -u ${DOCKER_USER} -p ${DOCKER_PASS}"
                    bat "docker push ${DOCKER_IMAGE}"
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution phase completed.'
        }
    }
}