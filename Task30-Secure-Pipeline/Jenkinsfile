pipeline {
    agent any

    tools {
        maven 'maven-3.9'
    }

    environment {
        DOCKER_IMAGE = "sadikshaik21/task30-app:latest"
    }

    stages {
        stage('Clone Repository') {
            steps {
                echo 'Pulling the latest source files...'
            }
        }

        stage('Gitleaks Secret Scan') {
            steps {
                echo 'Downloading and running Gitleaks...'
                sh '''
                    curl -sSLo gitleaks.tar.gz https://github.com/gitleaks/gitleaks/releases/download/v8.18.2/gitleaks_8.18.2_linux_x64.tar.gz
                    tar -xzf gitleaks.tar.gz gitleaks
                    chmod +x gitleaks
                    ./gitleaks detect --source . --verbose --exit-code=0
                '''
            }
        }

        stage('OWASP Dependency Scan') {
            steps {
                echo 'Invoking live OWASP dependency check inside Task30 directory...'
                // Step inside the subdirectory where pom.xml actually lives
                dir('Task30-Secure-Pipeline') {
                    sh 'mvn org.owasp:dependency-check-maven:check -DautoUpdate=false'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Simulating Docker build for: ${DOCKER_IMAGE}"
                dir('Task30-Secure-Pipeline') {
                    echo 'Skipping native docker build step due to environment missing docker engine binary...'
                }
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline execution phase completed.'
        }
    }
}