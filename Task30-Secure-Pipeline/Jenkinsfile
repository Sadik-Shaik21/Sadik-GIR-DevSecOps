pipeline {
    agent any

    tools {
        maven 'maven-3.9'
    }

    environment {
        IMAGE_NAME = "secure-app"
    }

    stages {

        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Tool Install') {
            steps {
                sh '''
                    java -version || true
                    mvn -version || true
                    git --version || true
                    curl --version || true
                '''
            }
        }

        stage('Clone Repository') {
            steps {
                echo 'Pulling the latest source files...'
            }
        }

        stage('Gitleaks Secret Scan') {
            steps {
                echo 'Downloading and running Gitleaks...'

                sh '''
                    rm -rf gitleaks
                    rm -f gitleaks.tar.gz

                    curl -L -o gitleaks.tar.gz https://github.com/gitleaks/gitleaks/releases/download/v8.24.2/gitleaks_8.24.2_linux_x64.tar.gz

                    tar -xzf gitleaks.tar.gz

                    chmod +x gitleaks

                    ./gitleaks version

                    ./gitleaks detect --source . --no-git --exit-code 0
                '''
            }
        }

        stage('OWASP Dependency Scan') {
            steps {
                sh '''
                    echo "OWASP Dependency-Check plugin not installed."
                    echo "Skipping this stage."
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    echo "Simulating Docker build..."
                    echo "docker build -t ${IMAGE_NAME}:latest ."
                '''
            }
        }

        stage('Trivy Security Scan') {
            steps {
                dir('/tmp') {
                    sh '''
                        rm -f trivy trivy.tar.gz

                        curl -L -o trivy.tar.gz https://github.com/aquasecurity/trivy/releases/download/v0.72.0/trivy_0.72.0_Linux-64bit.tar.gz

                        ls -lh trivy.tar.gz

                        tar -xzf trivy.tar.gz

                        chmod +x trivy

                        ./trivy --version

                        ./trivy fs --exit-code 0 --severity HIGH,CRITICAL $WORKSPACE
                    '''
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution phase completed. Task 30 Infrastructure Validated.'
        }

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed.'
        }
    }
}